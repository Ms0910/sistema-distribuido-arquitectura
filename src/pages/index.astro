---
// src/pages/index.astro
// Actividad 4 — Sistema Distribuido de Procesamiento de Tareas
// UI principal: Dashboard estilo GitHub, modo oscuro
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sistema Distribuido — Nodo Activo</title>
  <meta name="description" content="Simulación académica de un sistema distribuido con nodos, BroadcastChannel y Web Workers." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    /* ── Reset & Tokens ─────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0d1117;
      --surface:   #161b22;
      --border:    #30363d;
      --text:      #e6edf3;
      --muted:     #8b949e;
      --accent:    #58a6ff;
      --green:     #3fb950;
      --yellow:    #d29922;
      --red:       #f85149;
      --purple:    #bc8cff;
      --radius:    8px;
      --font-mono: 'JetBrains Mono', monospace;
      --font-sans: 'Inter', sans-serif;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-sans);
      min-height: 100vh;
      padding: 24px;
      line-height: 1.6;
    }

    /* ── Layout ─────────────────────────────────────────── */
    .app-shell {
      max-width: 960px;
      margin: 0 auto;
      display: grid;
      gap: 20px;
    }

    /* ── Header ─────────────────────────────────────────── */
    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--border);
    }

    .header-left h1 {
      font-size: 1.15rem;
      font-weight: 600;
      letter-spacing: -0.02em;
    }

    .header-left p {
      font-size: 0.78rem;
      color: var(--muted);
      margin-top: 2px;
    }

    .node-badge {
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 8px 14px;
    }

    .node-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--green);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(63, 185, 80, 0.4); }
      50%       { box-shadow: 0 0 0 6px rgba(63, 185, 80, 0); }
    }

    .node-id {
      font-family: var(--font-mono);
      font-size: 0.82rem;
      color: var(--accent);
      font-weight: 600;
    }

    /* ── Cards ──────────────────────────────────────────── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
    }

    .card-title {
      font-size: 0.78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .card-title .dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent);
    }

    /* ── Stats row ──────────────────────────────────────── */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 12px;
    }

    .stat-item {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px 16px;
    }

    .stat-label {
      font-size: 0.72rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .stat-value {
      font-family: var(--font-mono);
      font-size: 1.4rem;
      font-weight: 600;
      margin-top: 4px;
      color: var(--text);
    }

    .stat-value.accent { color: var(--accent); }
    .stat-value.green  { color: var(--green); }
    .stat-value.yellow { color: var(--yellow); }

    /* ── Worker progress bar ────────────────────────────── */
    .worker-section { display: none; }
    .worker-section.active { display: block; }

    .progress-bar-wrap {
      background: var(--bg);
      border-radius: 4px;
      height: 6px;
      overflow: hidden;
      margin-top: 10px;
    }

    .progress-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), var(--purple));
      border-radius: 4px;
      transition: width 0.3s ease;
      width: 0%;
    }

    .worker-status-text {
      font-family: var(--font-mono);
      font-size: 0.74rem;
      color: var(--muted);
      margin-top: 8px;
    }

    /* ── Event Log ──────────────────────────────────────── */
    .event-log {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      height: 340px;
      overflow-y: auto;
      padding: 12px;
      font-family: var(--font-mono);
      font-size: 0.75rem;
    }

    .event-log::-webkit-scrollbar { width: 4px; }
    .event-log::-webkit-scrollbar-track { background: transparent; }
    .event-log::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    .log-entry {
      display: grid;
      grid-template-columns: auto auto 1fr;
      gap: 10px;
      padding: 6px 0;
      border-bottom: 1px solid rgba(48, 54, 61, 0.4);
      align-items: start;
      animation: fadeIn 0.25s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-4px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .log-time { color: var(--muted); white-space: nowrap; }

    .log-badge {
      padding: 1px 7px;
      border-radius: 3px;
      font-size: 0.68rem;
      font-weight: 600;
      white-space: nowrap;
    }

    .badge-info     { background: rgba(88,166,255,0.15); color: var(--accent); }
    .badge-success  { background: rgba(63,185,80,0.15);  color: var(--green); }
    .badge-warning  { background: rgba(210,153,34,0.15); color: var(--yellow); }
    .badge-error    { background: rgba(248,81,73,0.15);  color: var(--red); }
    .badge-system   { background: rgba(188,140,255,0.15);color: var(--purple); }
    .badge-outgoing { background: rgba(63,185,80,0.1);   color: var(--green); }

    .log-msg { color: var(--text); word-break: break-word; }

    .log-empty {
      color: var(--muted);
      text-align: center;
      padding: 60px 0;
      font-size: 0.8rem;
    }

    /* ── Buttons ────────────────────────────────────────── */
    .btn-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 9px 18px;
      border-radius: var(--radius);
      border: 1px solid transparent;
      font-family: var(--font-sans);
      font-size: 0.84rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.15s ease;
      white-space: nowrap;
    }

    .btn-primary {
      background: var(--accent);
      color: #0d1117;
      border-color: var(--accent);
    }
    .btn-primary:hover { background: #79b8ff; transform: translateY(-1px); }
    .btn-primary:active { transform: translateY(0); }
    .btn-primary:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

    .btn-secondary {
      background: transparent;
      color: var(--text);
      border-color: var(--border);
    }
    .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }

    /* ── Pattern Legend ─────────────────────────────────── */
    .pattern-legend {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 12px;
    }

    .pattern-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px;
      position: relative;
      overflow: hidden;
    }

    .pattern-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 3px; height: 100%;
    }

    .pattern-card.singleton::before { background: var(--accent); }
    .pattern-card.observer::before  { background: var(--purple); }
    .pattern-card.worker::before    { background: var(--green); }
    .pattern-card.network::before   { background: var(--yellow); }

    .pattern-name {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 4px;
    }

    .pattern-card.singleton .pattern-name { color: var(--accent); }
    .pattern-card.observer  .pattern-name { color: var(--purple); }
    .pattern-card.worker    .pattern-name { color: var(--green); }
    .pattern-card.network   .pattern-name { color: var(--yellow); }

    .pattern-desc {
      font-size: 0.73rem;
      color: var(--muted);
      line-height: 1.5;
    }

    /* ── Footer ─────────────────────────────────────────── */
    .footer {
      text-align: center;
      font-size: 0.72rem;
      color: var(--muted);
      padding-top: 12px;
      border-top: 1px solid var(--border);
    }
  </style>
</head>
<body>
  <div class="app-shell">

    <!-- ══ HEADER ══ -->
    <header class="header">
      <div class="header-left">
        <h1>Sistema Distribuido — Dashboard</h1>
        <p>Cada pestaña del navegador representa un nodo independiente en la red.</p>
      </div>
      <div class="node-badge">
        <div class="node-dot"></div>
        <span class="node-id" id="nodeIdDisplay">Iniciando...</span>
      </div>
    </header>

    <!-- ══ ESTADÍSTICAS ══ -->
    <div class="card">
      <div class="card-title"><span class="dot"></span>Métricas del Nodo</div>
      <div class="stats-row">
        <div class="stat-item">
          <div class="stat-label">ID del Nodo</div>
          <div class="stat-value accent" id="statNodeId" style="font-size:1rem">—</div>
        </div>
        <div class="stat-item">
          <div class="stat-label">Mensajes Enviados</div>
          <div class="stat-value green" id="statSent">0</div>
        </div>
        <div class="stat-item">
          <div class="stat-label">Mensajes Recibidos</div>
          <div class="stat-value accent" id="statReceived">0</div>
        </div>
        <div class="stat-item">
          <div class="stat-label">Tareas Completadas</div>
          <div class="stat-value yellow" id="statCompleted">0</div>
        </div>
      </div>
    </div>

    <!-- ══ WORKER STATUS ══ -->
    <div class="card worker-section" id="workerSection">
      <div class="card-title"><span class="dot" style="background:var(--green)"></span>Web Worker — Hilo Secundario</div>
      <div class="worker-status-text" id="workerStatusText">Iniciando hilo...</div>
      <div class="progress-bar-wrap">
        <div class="progress-bar-fill" id="progressBar"></div>
      </div>
    </div>

    <!-- ══ LOG DE EVENTOS ══ -->
    <div class="card">
      <div class="card-title"><span class="dot" style="background:var(--yellow)"></span>Log de Eventos de Red</div>
      <div class="event-log" id="eventLog">
        <div class="log-empty" id="logEmpty">Esperando eventos de red... Abre otra pestaña para ver la comunicación entre nodos.</div>
      </div>
    </div>

    <!-- ══ ACCIONES ══ -->
    <div class="card">
      <div class="card-title"><span class="dot" style="background:var(--purple)"></span>Acciones del Nodo</div>
      <div class="btn-row">
        <button class="btn btn-primary" id="btnDispatch">
          Despachar Tarea Pesada a la Red
        </button>
        <button class="btn btn-secondary" id="btnPing">
          Enviar Heartbeat
        </button>
        <button class="btn btn-secondary" id="btnClear">
          Limpiar Log
        </button>
      </div>
    </div>

    <!-- ══ LEYENDA DE PATRONES ══ -->
    <div class="card">
      <div class="card-title"><span class="dot" style="background:var(--purple)"></span>Patrones de Diseño Implementados</div>
      <div class="pattern-legend">
        <div class="pattern-card singleton">
          <div class="pattern-name">■ Singleton</div>
          <div class="pattern-desc">NetworkManager garantiza una sola instancia de BroadcastChannel por pestaña. Archivo: <code>src/utils/NetworkManager.js</code>, método <code>getInstance()</code>.</div>
        </div>
        <div class="pattern-card observer">
          <div class="pattern-name">■ Observer</div>
          <div class="pattern-desc">La UI se suscribe a eventos de red con <code>subscribe(callback)</code>. Cuando llega un mensaje, el NetworkManager notifica a todos los observadores.</div>
        </div>
        <div class="pattern-card worker">
          <div class="pattern-name">■ Web Worker (Hilo)</div>
          <div class="pattern-desc">Las tareas pesadas corren en <code>public/worker.js</code> (hilo secundario). La UI nunca se congela. Comunicación via <code>postMessage</code>.</div>
        </div>
        <div class="pattern-card network">
          <div class="pattern-name">■ BroadcastChannel (Red)</div>
          <div class="pattern-desc">API nativa del navegador. Simula la "red" del sistema distribuido. Canal compartido: <code>'distributed-network'</code> entre todas las pestañas.</div>
        </div>
      </div>
    </div>

    <footer class="footer">
      Sistema Distribuido de Procesamiento de Tareas — Demo Académico &nbsp;·&nbsp;
      Singleton + Observer + Web Workers + BroadcastChannel
    </footer>
  </div>

  <!--
    LÓGICA DEL CLIENTE
    Todo este bloque corre EXCLUSIVAMENTE en el navegador.
    Astro no ejecuta nada de esto en el servidor.

    FLUJO:
    1. Se genera el ID único del nodo (esta pestaña).
    2. Se obtiene la instancia Singleton del NetworkManager.
    3. Se crea el Web Worker (hilo secundario).
    4. La UI se suscribe a eventos de red (Observer).
    5. Los botones envían mensajes a la red y/o al Worker.
  -->
  <script type="module">
    // Importamos los módulos de utilidades desde public/
    // (los archivos de src/ no son accesibles directamente por el browser en Astro)
    import { NetworkManager, MessageType, generateNodeId } from '/NetworkManager.js';

    // ── 1. Generar ID único del nodo ─────────────────────────────────────
    // Cada pestaña tiene su propio ID — simula el identificador de un nodo
    // en una red real (equivalente a una dirección IP o un nombre de host).
    const NODE_ID = generateNodeId();

    // ── 2. PATRÓN SINGLETON — obtener la instancia única del NetworkManager
    // Esta línea es el punto clave del Singleton: no importa cuántas veces
    // se llame, siempre devuelve el MISMO objeto NetworkManager.
    const network = NetworkManager.getInstance(NODE_ID);

    // ── 3. CREACIÓN DEL HILO (Web Worker)
    // new Worker() le indica al navegador que cree un NUEVO HILO y ejecute
    // worker.js en ese hilo. La UI no se bloqueará jamás por esa razón.
    const worker = new Worker('/worker.js');

    // ── Referencias al DOM ───────────────────────────────────────────────
    const nodeIdDisplay    = document.getElementById('nodeIdDisplay');
    const statNodeId       = document.getElementById('statNodeId');
    const statSent         = document.getElementById('statSent');
    const statReceived     = document.getElementById('statReceived');
    const statCompleted    = document.getElementById('statCompleted');
    const eventLog         = document.getElementById('eventLog');
    const logEmpty         = document.getElementById('logEmpty');
    const workerSection    = document.getElementById('workerSection');
    const workerStatusText = document.getElementById('workerStatusText');
    const progressBar      = document.getElementById('progressBar');
    const btnDispatch      = document.getElementById('btnDispatch');
    const btnPing          = document.getElementById('btnPing');
    const btnClear         = document.getElementById('btnClear');

    // Estado local del nodo
    let taskCounter    = 0;
    let sentCount      = 0;
    let receivedCount  = 0;
    let completedCount = 0;

    // ── Mostrar ID del nodo en la UI ─────────────────────────────────────
    nodeIdDisplay.textContent = NODE_ID;
    statNodeId.textContent    = NODE_ID;

    // ── Función: agregar entrada al log de eventos ───────────────────────
    function addLogEntry(message, badgeType = 'info', badgeLabel = 'RED') {
      if (logEmpty) logEmpty.style.display = 'none';

      const time = new Date().toLocaleTimeString('es-CO', { hour12: false });
      const entry = document.createElement('div');
      entry.className = 'log-entry';
      entry.innerHTML = `
        <span class="log-time">${time}</span>
        <span class="log-badge badge-${badgeType}">${badgeLabel}</span>
        <span class="log-msg">${message}</span>
      `;
      // Insertar al inicio para que los eventos más recientes aparezcan arriba
      eventLog.insertBefore(entry, eventLog.firstChild);

      // Limitar el log a 100 entradas para no saturar la memoria
      const entries = eventLog.querySelectorAll('.log-entry');
      if (entries.length > 100) entries[entries.length - 1].remove();
    }

    // ── 4. PATRÓN OBSERVER — suscribir la UI a eventos de red ───────────
    // La UI (Observer) le dice al NetworkManager (Subject) que quiere
    // ser notificada cada vez que llegue un mensaje de la red.
    // El NetworkManager no sabe quién lo escucha; solo notifica.
    network.subscribe((message) => {
      const { type, senderId, payload, direction } = message;
      const isLocal    = direction === 'OUTGOING';
      const sourceTag  = isLocal ? `[YO: ${NODE_ID}]` : `[${senderId}]`;
      const badgeType  = isLocal ? 'outgoing' : 'info';
      const badgeLabel = isLocal ? 'ENVIADO' : 'RECIBIDO';

      if (!isLocal) {
        receivedCount++;
        statReceived.textContent = receivedCount;
      }

      // Renderizar el evento en el log según su tipo
      switch (type) {
        case MessageType.NODE_JOINED:
          addLogEntry(`${sourceTag} Nuevo nodo conectado a la red.`, isLocal ? 'outgoing' : 'success', 'NODO');
          break;
        case MessageType.NODE_LEFT:
          addLogEntry(`${sourceTag} Nodo desconectado. Uptime: ${Math.round((payload?.uptime || 0) / 1000)}s`, 'warning', 'NODO');
          break;
        case MessageType.TASK_DISPATCHED:
          addLogEntry(`${sourceTag} Tarea [${payload?.taskId}] despachada. Iteraciones: ${(payload?.iterations || 0).toLocaleString()}`, badgeType, 'TAREA');
          break;
        case MessageType.TASK_ACCEPTED:
          addLogEntry(`${sourceTag} Worker aceptó tarea [${payload?.taskId}]`, 'system', 'WORKER');
          break;
        case MessageType.TASK_PROGRESS:
          addLogEntry(`${sourceTag} Tarea [${payload?.taskId}] — ${payload?.progress}% completado`, 'system', 'PROGRESO');
          break;
        case MessageType.TASK_COMPLETED:
          addLogEntry(`${sourceTag} Tarea [${payload?.taskId}] completada. Resultado: ${(payload?.result || 0).toLocaleString()}`, 'success', 'LISTO');
          break;
        case MessageType.HEARTBEAT:
          addLogEntry(`${sourceTag} Heartbeat — Nodo activo`, badgeType, 'PING');
          break;
        default:
          addLogEntry(`${sourceTag} [${type}] ${JSON.stringify(payload).substring(0, 80)}`, badgeType, badgeLabel);
      }
    });

    // ── Escuchar mensajes del Worker (comunicación entre hilos) ──────────
    // El hilo principal recibe actualizaciones del Worker via postMessage.
    // Nunca se bloquea esperando — es comunicación completamente asíncrona.
    worker.addEventListener('message', (event) => {
      const { type, taskId, message, progress, result } = event.data;

      switch (type) {
        case 'TASK_STARTED':
          addLogEntry(`[HILO SECUNDARIO] ${message}`, 'system', 'HILO');
          workerSection.classList.add('active');
          workerStatusText.textContent = message;
          progressBar.style.width = '0%';
          // Notificar a la red que este nodo aceptó la tarea
          network.broadcast(MessageType.TASK_ACCEPTED, { taskId, nodeId: NODE_ID });
          sentCount++; statSent.textContent = sentCount;
          break;

        case 'TASK_PROGRESS':
          workerStatusText.textContent = message;
          progressBar.style.width = `${progress}%`;
          // Broadcast del progreso a la red
          network.broadcast(MessageType.TASK_PROGRESS, { taskId, progress, nodeId: NODE_ID });
          sentCount++; statSent.textContent = sentCount;
          break;

        case 'TASK_COMPLETED':
          addLogEntry(`[HILO SECUNDARIO] ${message}`, 'success', 'HILO');
          workerStatusText.textContent = `Completado — Resultado: ${result.toLocaleString()} ops`;
          progressBar.style.width = '100%';
          // Broadcast del resultado final a toda la red
          network.broadcast(MessageType.TASK_COMPLETED, { taskId, result, nodeId: NODE_ID });
          sentCount++; statSent.textContent = sentCount;
          completedCount++;
          statCompleted.textContent = completedCount;
          btnDispatch.disabled = false;
          btnDispatch.textContent = 'Despachar Tarea Pesada a la Red';
          // Ocultar la barra de progreso después de 3s
          setTimeout(() => workerSection.classList.remove('active'), 3000);
          break;
      }
    });

    // ── Botón: Despachar tarea pesada ────────────────────────────────────
    // 1. Anuncia la tarea a la RED  (BroadcastChannel — otros nodos)
    // 2. Envía el trabajo al WORKER (hilo secundario — este mismo nodo)
    btnDispatch.addEventListener('click', () => {
      taskCounter++;
      const taskId     = `TASK-${NODE_ID}-${taskCounter}`;
      const iterations = 50_000_000; // 50 millones de operaciones

      btnDispatch.disabled = true;
      btnDispatch.textContent = 'Procesando en hilo secundario...';

      // Paso 1 — Comunicación de RED: anunciar la tarea a todos los nodos
      network.broadcast(MessageType.TASK_DISPATCHED, { taskId, iterations, nodeId: NODE_ID });
      sentCount++; statSent.textContent = sentCount;

      // Paso 2 — Comunicación de HILO: enviar el trabajo al Worker
      // A partir de aquí el cálculo ocurre en el hilo secundario.
      // El Main Thread (UI) sigue respondiendo con normalidad.
      worker.postMessage({ taskId, payload: { iterations } });

      addLogEntry(`Tarea [${taskId}] enviada al Worker. La UI permanece activa.`, 'warning', 'DISPATCH');
    });

    // ── Botón: Heartbeat ─────────────────────────────────────────────────
    // Envía una señal de vida a todos los nodos de la red.
    btnPing.addEventListener('click', () => {
      network.broadcast(MessageType.HEARTBEAT, {
        nodeId: NODE_ID,
        uptime: network.uptime,
        stats:  network.stats,
      });
      sentCount++; statSent.textContent = sentCount;
    });

    // ── Botón: Limpiar log ───────────────────────────────────────────────
    btnClear.addEventListener('click', () => {
      eventLog.innerHTML = '';
      const empty = document.createElement('div');
      empty.className = 'log-empty';
      empty.textContent = 'Log limpiado. Esperando nuevos eventos...';
      eventLog.appendChild(empty);
    });

    // ── Inicialización ───────────────────────────────────────────────────
    // Anunciar que este nodo se conectó a la red
    network.broadcast(MessageType.NODE_JOINED, { nodeId: NODE_ID });
    sentCount++; statSent.textContent = sentCount;

    addLogEntry(
      `Nodo ${NODE_ID} conectado a la red distribuida. Abre más pestañas para ver la comunicación.`,
      'system', 'SISTEMA'
    );

    // ── Cleanup al cerrar la pestaña ─────────────────────────────────────
    // Anunciar desconexión a la red y liberar el Worker y el canal.
    window.addEventListener('beforeunload', () => {
      worker.terminate();
      network.disconnect();
    });

    // Sincronizar el contador de mensajes recibidos cada segundo
    setInterval(() => {
      statReceived.textContent = network.stats.messagesReceived;
    }, 1000);
  </script>
</body>
</html>
